{
  "name": "pi-zig-bun",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "precommit": "./scripts/pre-commit.sh",
    "validate": "bunx tsc --noEmit",
    "test": "bun test",
    "test:zig": "zig test src/zig/main.zig",
    "ci:search-regression": "bun scripts/ci-search-regression.ts",
    "ci:perf": "bun scripts/perf-gates.ts",
    "ci:requirements-coverage": "bun scripts/check-requirements-coverage.ts",
    "ci": "bun run validate && bun run test && bun run test:zig && zig build && bun run ci:search-regression && bun run ci:perf && bun run ci:requirements-coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
